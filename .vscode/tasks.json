{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Run (make)",
            "type": "shell",
            "command": "make",
            "args": [
                "CXXFLAGS+=-g -O0",
                "CFLAGS+=-g -O0"
            ],
            "options": {
                "cwd": "${fileDirname}"
            },
            "problemMatcher": ["$gcc"],
            "group": {
                "kind": "build",
                "isDefault": true
            }
        }
    ]
}
